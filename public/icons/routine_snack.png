  <!-- Smile -->
  <path d="M213 288 Q231 302 250 288" stroke="#3B1F08" stroke-width="2.8" fill="none" stroke-linecap="round" style="fill:none;stroke:rgb(59, 31, 8);color:rgb(255, 255, 255);stroke-width:2.8px;stroke-linecap:round;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Rosy cheeks -->
  <ellipse cx="196" cy="289" rx="10" ry="7" fill="#E87A5A" opacity="0.35" style="fill:rgb(232, 122, 90);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.35;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <ellipse cx="264" cy="284" rx="10" ry="7" fill="#E87A5A" opacity="0.35" style="fill:rgb(232, 122, 90);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.35;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- ===== GLASS OF MILK ===== -->

  <!-- Glass body (trapezoid shape) -->
  <!-- Back of glass -->
  <path d="M428 150 L512 150 L530 340 L410 340 Z" fill="#CCE9F5" opacity="0.35" style="fill:rgb(204, 233, 245);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.35;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- Milk fill inside glass -->
